# Enforce bzlmod lockfile usage
common --lockfile_mode=error

# Enable repository cache
build --repository_cache=~/.cache/bazel/repository_cache

# Enable disk cache
build --disk_cache=~/.cache/bazel-disk-cache

# Stabilize PATH
build --incompatible_strict_action_env=true
build --action_env=PATH
build --host_action_env=PATH
build --action_env=LD_LIBRARY_PATH
build --host_action_env=LD_LIBRARY_PATH
build --action_env=JAVA_HOME
build --host_action_env=JAVA_HOME
build --action_env=BAZEL_JAVA_HOME
build --host_action_env=BAZEL_JAVA_HOME
build --action_env=CHISEL_FIRTOOL_PATH
build --host_action_env=CHISEL_FIRTOOL_PATH
build --action_env=LC_ALL=C
build --host_action_env=LC_ALL=C
build --action_env=TZ=UTC
build --host_action_env=TZ=UTC

# Performance optimizations
build --remote_cache_compression
build --action_env=COURSIER_CACHE
build --host_action_env=COURSIER_CACHE
